<!ELEMENT info (#PCDATA)>
<!ELEMENT type (#PCDATA)>
<!ELEMENT date (#PCDATA)>
<!ELEMENT price (#PCDATA)>
<!ELEMENT turn (#PCDATA)>
<!ELEMENT specialty (#PCDATA)>
<!ELEMENT category (#PCDATA)>
<!ELEMENT quantity (#PCDATA)>
<!ELEMENT expiration_date (#PCDATA)>
<!ELEMENT username (#PCDATA)>
<!ELEMENT password (#PCDATA)>
